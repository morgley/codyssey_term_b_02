        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen2.5:3b\",\n  \"system\": \"당신은 한국어 뉴스 요약 전문가입니다. 모든 답변은 반드시 한국어로만 작성하세요. 중국어와 영어는 사용하지 마세요.\",\n  \"prompt\": {{ JSON.stringify(\"다음 뉴스 기사를 반드시 한국어로만 요약하세요.\\n\\n[출력 형식]\\n요약:\\n1. \\n2. \\n3. \\n\\n핵심 키워드:\\n- \\n- \\n- \\n\\n제목: \" + ($('Select One AI News').item.json.title || \"\") + \"\\n\\n본문: \" + (($('Select One AI News').item.json.content || \"\").slice(0, 3000)) + \"\\n\\nURL: \" + ($('Select One AI News').item.json.link || \"\")) }},\n  \"stream\": false\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1632,
        64
      ],
      "id": "a34974fe-e715-4545-967d-20cd6fcbdae7",
      "name": "Summarize with Ollama",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
      "credentials": {
        "openAiApi": {
          "id": "1K5DT8BLOG5MNe61",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const news = $('Select One AI News').first().json;\nconst ollama = $input.first().json;\n\n// Ollama 요약 결과\nconst summary = ollama.response || '요약 결과 없음';\n\n// Notion 텍스트 길이 제한 대비\nfunction truncate(text, max = 1900) {\n  if (!text) return '';\n  text = String(text);\n  return text.length > max ? text.slice(0, max) + '...' : text;\n}\n\n// 키워드 추출 시도\nfunction extractKeywords(text) {\n  const keywordSection = text.match(/핵심\\s*키워드[\\s\\S]*/);\n  if (!keywordSection) return '';\n\n  return keywordSection[0]\n    .split('\\n')\n    .map(line => line.replace(/^[-*\\d.\\s]+/, '').trim())\n    .filter(line => line && !line.includes('핵심'))\n    .slice(0, 5)\n    .join(', ');\n}\n\nreturn [\n  {\n    json: {\n      title: truncate(news.title, 200),\n      url: news.link || news.url || '',\n      source: news.source || news.feedTitle || 'RSS',\n      publishedAt: news.pubDate || news.isoDate || news.publishedAt || new Date().toISOString(),\n      summary: truncate(summary, 1900),\n      keywords: extractKeywords(summary),\n      originalContent: truncate(news.content || news.contentSnippet || news.description || '', 1900),\n\n      // 중요: 중복 확인용 키를 반드시 넘겨야 함\n      uniqueKey: news.uniqueKey || '',\n\n      // 저장 상태\n      status: 'Saved',\n\n      createdAt: new Date().toISOString()\n    }\n  }\n];"
      },
