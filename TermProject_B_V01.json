      "id": "57208a45-451e-40df-9fe2-435483c38cf7",
      "name": "Read Tech RSS 2",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "// RSS 기사 중 AI 관련 뉴스만 필터링하고 최신 1건만 선택하는 코드\n\n// 1. AI 관련 키워드 목록\nconst keywords = [\n  'ai',\n  'artificial intelligence',\n  'generative ai',\n  'llm',\n  'large language model',\n  'chatgpt',\n  'openai',\n  'anthropic',\n  'google deepmind',\n  'machine learning',\n  'deep learning',\n  'agent',\n  'ai agent',\n  '인공지능',\n  '생성형 ai',\n  '머신러닝',\n  '딥러닝'\n];\n\n// 2. 간단한 문자열 해시 함수\n// 원문 링크를 기반으로 UniqueKey를 만들기 위해 사용\nfunction simpleHash(str) {\n  let hash = 0;\n\n  if (!str) return 'no-link';\n\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash = hash & hash;\n  }\n\n  return 'news_' + Math.abs(hash).toString();\n}\n\n// 3. RSS에서 들어온 전체 아이템 가져오기\nconst items = $input.all();\n\n// 4. RSS 데이터 정리\nconst normalizedItems = items.map(item => {\n  const data = item.json;\n\n  const title = data.title || '';\n  const link = data.link || data.guid || '';\n  const pubDate = data.pubDate || data.isoDate || data.date || new Date().toISOString();\n\n  // RSS마다 본문 필드명이 다를 수 있으므로 여러 후보를 합침\n  const content = [\n    data.content,\n    data.contentSnippet,\n    data.description,\n    data.summary\n  ].filter(Boolean).join('\\n');\n\n  const searchText = `${title}\\n${content}`.toLowerCase();\n\n  return {\n    title,\n    link,\n    pubDate,\n    content,\n    searchText,\n    guid: data.guid || '',\n    source: data.creator || data.author || 'Tech RSS',\n    original: data\n  };\n});\n\n// 5. 키워드 포함 여부로 AI 관련 기사 필터링\nconst filteredItems = normalizedItems.filter(article => {\n  return keywords.some(keyword => article.searchText.includes(keyword.toLowerCase()));\n});\n\n// 6. AI 관련 기사가 없을 경우\n// 다음 노드에서 처리할 수 있도록 noNews 상태를 넘김\nif (filteredItems.length === 0) {\n  return [\n    {\n      json: {\n        noNews: true,\n        status: 'NoNews',\n        message: 'AI 관련 뉴스가 RSS에서 발견되지 않았습니다.',\n        checkedAt: new Date().toISOString()\n      }\n    }\n  ];\n}\n\n// 7. 최신순 정렬\nfilteredItems.sort((a, b) => {\n  return new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime();\n});\n\n// 8. 최신 기사 1건 선택\nconst selected = filteredItems[0];\n\n// 9. UniqueKey 생성\n// link가 있으면 link 기반, 없으면 guid 기반\nconst keySource = selected.link || selected.guid || selected.title;\nconst uniqueKey = simpleHash(keySource);\n\n// 10. 다음 노드로 넘길 데이터 구성\nreturn [\n  {\n    json: {\n      noNews: false,\n      status: 'Selected',\n      title: selected.title,\n      link: selected.link,\n      pubDate: selected.pubDate,\n      content: selected.content,\n      uniqueKey: uniqueKey,\n      source: selected.source,\n      keywordMatched: true,\n      selectedAt: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
